# ============================================================================
# Silica — configuration
# Copy this file to .env. Every line is commented out; defaults apply when
# unset. Ordered from essential to expert: stop reading when you have enough.
# ============================================================================


# ----------------------------------------------------------------------------
# 1. REQUIRED (the first-run wizard fills these for you)
# ----------------------------------------------------------------------------

# Main LLM model (litellm format).
# Examples: openrouter/anthropic/claude-sonnet-4-20250514, openai/gpt-4o,
#           ollama/llama3.1:8b, lmstudio/qwen/qwen3.5-9b
# SILICA_MODEL=openrouter/google/gemini-3.5-flash

# Provider preset (derived from SILICA_MODEL when unset).
# One of: openrouter, lmstudio, ollama, gemini, openai, groq, deepseek,
# mistral, xai, custom. Silica is tool-driven — with ollama pick a model that
# supports function-calling (llama3.1, qwen2.5); text-only models will stall.
# SILICA_PROVIDER=openrouter

# API key for the provider above. ANTHROPIC_API_KEY / OPENAI_API_KEY are only
# needed when SILICA_MODEL targets that provider directly (litellm reads them).
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Obsidian vault path (required for the default fs backend)
# SILICA_VAULT=/path/to/your/vault


# ----------------------------------------------------------------------------
# 2. CUSTOM ENDPOINT — only with SILICA_PROVIDER=custom
# ----------------------------------------------------------------------------
# Any OpenAI-compatible server without a dedicated preset: vLLM, llama.cpp,
# LocalAI, Jan, or a hosted vendor. Both variables route the "custom" preset.

# SILICA_PROVIDER_BASE_URL=http://localhost:8080/v1
# SILICA_PROVIDER_API_KEY=


# ----------------------------------------------------------------------------
# 3. RACCOMANDED OPTIONS — embeddings, vault behavior, UI
# ----------------------------------------------------------------------------

# Embedding model for semantic search and deduplication.
# Example: qwen3-embedding-4b (LM Studio), text-embedding-3-small (OpenAI)
# SILICA_EMBEDDING_MODEL=qwen3-embedding-4b

# Embeddings endpoint (defaults to LM Studio local) and its API key
# SILICA_EMBEDDING_BASE_URL=http://localhost:1234/v1
# SILICA_EMBEDDING_API_KEY=lm-studio

# Git commit safety net for vault writes: off (default) or auto
# SILICA_GIT_COMMIT=off

# Inbox folder inside the vault, for staging inbound files. Default: Inbox
# SILICA_INBOX_DIR=Inbox

# Tool progress display level: off, new, all, verbose
# SILICA_TOOL_PROGRESS=all

# Show reasoning/thinking blocks from the model (True/False)
# SILICA_SHOW_THINKING=True

# Startup banner art (True → wordmark, False → plain one-liner)
# SILICA_SHOW_BANNER=True

# Debug logging on stderr (True/False)
# SILICA_VERBOSE=False


# ----------------------------------------------------------------------------
# 4. ADVANCED — workers, context, search, PDF
# ----------------------------------------------------------------------------

# Sub-agent worker model for background tasks (dedup, refiner). If unset,
# workers fall back to the main model configuration.
# SILICA_WORKER_MODEL=lmstudio/qwen/qwen3.5-9b
# SILICA_WORKER_PROVIDER=lmstudio
# SILICA_WORKER_API_KEY=lm-studio

# Concurrency caps: sub-agent threads (default 3), worker LLM calls (default 4)
# SILICA_SUBAGENT_MAX_CONCURRENT=3
# SILICA_WORKER_MAX_CONCURRENT=4

# Context window pin for LOCAL providers (LM Studio, Ollama) only; OpenRouter
# always uses the provider-reported context_length. Auto-detected if unset.
# SILICA_MAX_CONTEXT=60000

# Max generation tokens fallback. Default: 256000
# MAX_TOKENS=256000

# Tavily API key (enables /web-search). Bare TAVILY_API_KEY works as fallback.
# SILICA_TAVILY_API_KEY=

# PDF-to-Markdown converter: mineru (default, silica[pdf] extra), docling, or
# opendataloader. OCR languages are used by docling only.
# SILICA_PDF_PROVIDER=mineru
# SILICA_PDF_OCR_LANG=en,it,fr,de,es

# Driver backend: fs (default, headless filesystem). The Obsidian plugin
# bridge installs the ws backend live at dial-in; never set ws here.
# SILICA_BACKEND=fs

# Vault display name (prompt fallback when no vault path is set)
# SILICA_VAULT_NAME=My Vault

# Domain-pack overlay name, and override dir for recipe packs
# SILICA_DOMAIN=
# SILICA_DOMAINS_DIR=


# ----------------------------------------------------------------------------
# 5. RERANKER — optional recall reordering
# ----------------------------------------------------------------------------
# A cross-encoder reads query and candidate TOGETHER and reorders recall
# results. It is not an LLM and not an embedding model, so LM Studio and
# Ollama cannot serve one. The supported way needs no variables here:
#
#     pip install silica[rerank]
#
# The cross-encoder then runs inside Silica (~2GB weights on first use).
# The variables below only point Silica at a reranker you already serve
# (llama.cpp/Infinity/Jina/Cohere, /rerank protocol); all three must be set
# and take priority over the in-process one. Local llama.cpp example:
#   llama-server -m bge-reranker-v2-m3.gguf --reranking --port 1235
# SILICA_RERANK_BASE_URL=http://localhost:1235/v1
# SILICA_RERANK_MODEL=bge-reranker-v2-m3
# SILICA_RERANK_API_KEY=lm-studio


# ----------------------------------------------------------------------------
# 6. EXPERT — similarity thresholds, mindmap, token budgets
# ----------------------------------------------------------------------------
# All have safe defaults; override only to tune behavior/cost.

# Dedup: ≥ HIGH → patch existing note; ≤ LOW → new note. Title threshold
# promotes a pair into the borderline window; THEME is the keep floor.
# SILICA_SIM_THRESHOLD_HIGH=0.85
# SILICA_SIM_THRESHOLD_LOW=0.65
# SILICA_SIM_TITLE_THRESHOLD=0.80
# SILICA_SIM_THRESHOLD_THEME=0.35

# Candidate notes retrieved per note during dedup scans. Default: 5
# SILICA_DEDUP_SCAN_K=5

# Language for the co-occurrence graph. Default: auto
# SILICA_COOCCURRENCE_LANG=auto

# Mindmap (/map <note>): node cap, latent neighbours, wikilink BFS depth
# SILICA_MINDMAP_MAX_NODES=35
# SILICA_MINDMAP_LATENT_K=10
# SILICA_MINDMAP_HOPS=2

# Per-capability generation ceilings and distiller chunking.
# NOTE: read WITHOUT the SILICA_ prefix (bare names).
# DEDUP_MAX_TOKENS=1024
# ORPHAN_MAX_TOKENS=512
# EXPAND_MAX_TOKENS=4096
# ENRICH_MAX_TOKENS=256000
# REFINE_MAX_TOKENS=256000
# MODEL_CONTEXT_WINDOW=0             # 0 = auto-detect from the model
# DISTILLER_MAX_TOKENS=0             # 0 = derive from context window
# DISTILLER_TOKEN_SAFETY_MARGIN=2048
# DISTILLER_CHUNK_MAX_BYTES=30720    # 30 * 1024
