# Silica Agent — Configuration
# Copy this file to .env and fill in your values.

# LLM Model (litellm format)
# Examples: openrouter/anthropic/claude-sonnet-4-20250514, anthropic/claude-sonnet-4-20250514, openai/gpt-4o
# SILICA_MODEL=openrouter/google/gemini-3.5-flash

# LLM Provider override (derived from SILICA_MODEL by default)
# Examples: openrouter, lmstudio
# SILICA_PROVIDER=openrouter

# API Keys (set the one matching your provider)
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Obsidian vault path (for fs backend)
# SILICA_VAULT=/path/to/your/vault

# Obsidian CLI vault name (for multi-vault setups)
# SILICA_VAULT_NAME=My Vault

# Driver backend: cli (default, requires Obsidian desktop) or fs (headless)
# SILICA_BACKEND=cli

# Inbox folder inside the vault (used to archive and blacklist staging files)
# SILICA_INBOX_DIR=Inbox

# Max context tokens before warning
# SILICA_MAX_CONTEXT=60000

# Tool progress display level: off, new, all, verbose
# SILICA_TOOL_PROGRESS=all

# Debug logging on stderr (True/False)
# SILICA_VERBOSE=False

# Show reasoning/thinking blocks from the model (True/False)
# SILICA_SHOW_THINKING=True

# Startup banner pyfiglet font
# SILICA_BANNER_FONT=slant

# Startup banner style: crystal, wordmark, minimal
# SILICA_BANNER_STYLE=wordmark
